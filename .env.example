# MT3 Transcription Configuration
# Copy this to .env and fill in your values

# Django — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=
DEBUG=False

# Additional allowed hosts/origins (comma-separated, for deployment)
# EXTRA_ALLOWED_HOSTS=your.server.ip
# EXTRA_CSRF_ORIGINS=http://your.server.ip:3000
# EXTRA_CORS_ORIGINS=http://your.server.ip:3000

# Async processing (requires Redis + Dramatiq + GPU)
IS_ASYNC=False
REDIS_URL=redis://localhost:6379

# Mailgun (for email features)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.yourdomain.com
