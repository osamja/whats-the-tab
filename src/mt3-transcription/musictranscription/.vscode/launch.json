{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django: Debug Server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/mt3-transcription/musictranscription/manage.py",
            "args": [
                "runserver",
                "0:8008"
            ],
            "django": true,
            "justMyCode": false,
            "console": "integratedTerminal",
            "env": {
                "PYTHONUNBUFFERED": "1"
            },
            "cwd": "${workspaceFolder}/src/mt3-transcription/musictranscription"
        }
    ]
}
