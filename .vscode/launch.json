{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Django runserver",
        "type": "debugpy",
        "request": "launch",
        "program": "${workspaceFolder}/src/mt3-transcription/musictranscription/manage.py",
        "args": [
          "runserver",
          "0.0.0.0:8008"
        ],
        "django": true,
        // "justMyCode": true,
        "env": {
            "PYTHONPATH": "${workspaceFolder}/src/mt3-transcription/musictranscription",
            "VIRTUAL_ENV": "${workspaceFolder}/src/mt3-transcription/venv",
            "PATH": "${workspaceFolder}/src/mt3-transcription/venv:${env:PATH}"
        },
        "cwd": "${workspaceFolder}/src/mt3-transcription/musictranscription"
      }
    ]
  }
  